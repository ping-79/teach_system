<%- include('../partials/head', { title }) %>
<%- include('../partials/header') %>
<main class="page-shell">
  <%- include('../partials/flash') %>
  <section class="panel">
    <div class="section-head">
      <div>
        <p class="eyebrow">Review</p>
        <h1>确认课程内容：<%= library.courseName %></h1>
      </div>
      <p><%= library.displaySourceFilename %> · <%= library.teacher?.name || '' %></p>
    </div>

    <form method="post" action="/content-library/import/<%= library.id %>/confirm" class="stack-form">
      <div class="table-wrap">
        <table class="edit-table">
          <thead>
            <tr>
              <th>序号</th>
              <th>教学内容（章节/主题）</th>
              <th>学时</th>
              <th>理论</th>
              <th>实践</th>
            </tr>
          </thead>
          <tbody>
            <% (draftItems.length ? draftItems : [{}, {}, {}, {}]).forEach((item, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td>
                  <textarea name="items[<%= index %>][topicTitle]" rows="2"><%= item.topicTitle || '' %></textarea>
                </td>
                <td>
                  <input type="number" step="0.5" name="items[<%= index %>][suggestedHours]" value="<%= item.suggestedHours ?? '' %>">
                </td>
                <td>
                  <input type="number" step="0.5" name="items[<%= index %>][theoryHours]" value="<%= item.theoryHours ?? '' %>">
                </td>
                <td>
                  <input type="number" step="0.5" name="items[<%= index %>][practiceHours]" value="<%= item.practiceHours ?? '' %>">
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <button type="submit" class="primary-button">确认并保存到资料库</button>
    </form>
  </section>
</main>
<%- include('../partials/footer') %>
