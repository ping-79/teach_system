<%- include('../partials/head', { title }) %>
<%- include('../partials/header') %>
<main class="page-shell">
  <%- include('../partials/flash') %>

  <section class="panel compact-panel">
    <div class="section-head">
      <div>
        <p class="eyebrow">Password</p>
        <h1>修改教师密码</h1>
      </div>
      <p><%= teacher.name %>（<%= teacher.employeeNo %>）</p>
    </div>

    <form method="post" action="/admin/teachers/<%= teacher.id %>/password" class="stack-form slim-form">
      <label>
        <span>新密码</span>
        <input type="password" name="password" minlength="8" placeholder="请输入不少于 8 位的新密码" required>
      </label>
      <div class="action-row">
        <button type="submit" class="primary-button">保存新密码</button>
        <a class="ghost-button" href="/admin/teachers">返回教师账号管理</a>
      </div>
    </form>
  </section>
</main>
<%- include('../partials/footer') %>
